# Meshes API Credentials
# Copy this file to .env and fill in your values.
# Get these from https://meshes.io → Settings → Machine Keys

# Management API (access key + secret key + org ID)
MESHES_ACCESS_KEY=mk_your_access_key
MESHES_SECRET_KEY=your_secret_key
MESHES_ORG_ID=00000000-0000-0000-0000-000000000000

# Event Ingestion (publishable key)
MESHES_PUBLISHABLE_KEY=pub_your_publishable_key

# Optional: override API URL for local development
# MESHES_API_URL=http://localhost:3000
